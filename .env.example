# ──────────────────────────────────────────────────────────────────
# ULTRONOS — Etsy AI Dashboard  |  copy to .env and fill in values
# NEVER commit .env to git (already in .gitignore)
# ──────────────────────────────────────────────────────────────────

# Etsy API (get a key: https://developers.etsy.com/documentation/essentials/authentication)
ETSY_API_KEY=your_etsy_api_key
ETSY_SHOP_ID=your_etsy_shop_id
# ETSY_ACCESS_TOKEN=your_oauth_token   # needed for order & revenue data (OAuth 2.0)

# Local Ollama AI — no API key needed, runs on your machine
OLLAMA_HOST=http://localhost:11434
HERMES_MODEL=hermes3
GEMMA_MODEL=gemma4

# Hermes Agent log file (absolute or relative to project root)
HERMES_LOG_PATH=./hermes-agent.log

# Print-on-demand (optional — add when you integrate)
# PRINTFUL_API_KEY=your_printful_key
# PRINTIFY_API_KEY=your_printify_key

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Frontend (VITE_ prefix exposes vars to browser bundle)
VITE_API_BASE_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
